# ============================================================
# 环境变量示例（复制为 .env 后填写；.env 不要提交 Git）
# ============================================================

# ── 大模型（各智能体共用；OPENAI_API_KEY 不填则自动降级 Mock，可独立运行/测试）──
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_USE_MOCK=true

# ── 人员 B 智能体端口 ──
PROFILE_PORT=8081
TUTOR_PORT=8082
EVALUATOR_PORT=8080
SAFETY_PORT=8083

# ── 人员 C：资源生成编排器（启动时 PORT=8090）──
FILE_STORAGE_PATH=./storage
PUBLIC_BASE_URL=http://localhost:8090/files
ENABLE_SAFETY_CHECK=true
# 网关内部推送地址（WS 进度通知走网关转发）
GATEWAY_PUSH_URL=

# ── 人员 C：路径规划智能体（启动时 PORT=8091）──
BIND_MATCH_THRESHOLD=0.3

# ── 数据库（后续补充）──
# DATABASE_URL=sqlite:///./data/learning.db
